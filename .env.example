# Neon pooled connection string for app runtime.
# In Neon Connect modal, enable connection pooling / pooler.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/HabitHug?sslmode=require"

# Neon direct connection string for Prisma migration/deploy.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/HabitHug?sslmode=require"

# 32+ random chars. Example generation:
# openssl rand -base64 32
SESSION_SECRET="replace-with-long-random-secret"

# Optional. Set this to your Vercel production URL after deploy.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
